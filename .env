# Database Configuration (MariaDB)
# Format: mysql://user:password@host:port/database
DATABASE_URL="mysql://root:password@localhost:3306/novaleap"

# Next.js Environment
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Contact Form Email (Titan SMTP)
TITAN_SMTP_HOST="smtp.titan.email"
TITAN_SMTP_PORT="465"
TITAN_SMTP_USER="your-titan-email@yourdomain.com"
TITAN_SMTP_PASS="your-titan-password"
TITAN_SMTP_FROM="your-titan-email@yourdomain.com"
CONTACT_NOTIFICATION_EMAIL="your-titan-email@yourdomain.com"

# Admin Dashboard Credentials
ADMIN_EMAIL="admin@novaleap.com"
ADMIN_PASSWORD="admin_strong_password_here"
